{
  "name": "internship-application-os",
  "version": "1.0.0",
  "author": "Internship OS",
  "private": true,
  "description": "Local-first SWE internship tracker and LaTeX resume workspace",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "ensure:electron": "node scripts/ensure-electron.mjs",
    "predev": "npm run ensure:electron",
    "dev": "electron-vite dev",
    "predev:fresh": "npm run ensure:electron",
    "dev:fresh": "node scripts/dev-fresh.mjs",
    "doctor": "tsx scripts/doctor.ts",
    "build": "npm run typecheck && electron-vite build",
    "package:mac": "npm run build && electron-builder --mac dir --publish never",
    "install:mac": "npm run package:mac && node scripts/install-mac.mjs",
    "sync:mac": "node scripts/install-mac.mjs",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run ensure:electron",
    "test": "ELECTRON_RUN_AS_NODE=1 electron ./node_modules/vitest/vitest.mjs run",
    "preios": "npm run ensure:electron",
    "ios": "ELECTRON_RUN_AS_NODE=1 electron ./node_modules/tsx/dist/cli.mjs src/cli/index.ts",
    "skills:sync": "node scripts/vendor-resume-skills.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@uiw/codemirror-theme-xcode": "^4.25.11",
    "@uiw/react-codemirror": "^4.25.11",
    "better-sqlite3": "^12.2.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.4",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.internshipos.desktop",
    "productName": "Internship OS",
    "files": [
      "out/**/*",
      "main.tex",
      "resources/assistant-tools/**/*",
      "resources/resume-skills/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    }
  }
}
